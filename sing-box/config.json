{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "proxy-dns",
        "type": "https",
        "server": "dns.google",
        "server_port": 443,
        "detour": "proxy"
      },
      {
        "tag": "local-dns",
        "type": "udp",
        "server": "1.1.1.1",
        "server_port": 53
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          "codeium.com",
          "jetbrains.com",
          "jetbrains.ai",
          "cloudflare.com",
          "cloudfront.net",
          "chatgpt.com",
          "openai.com",
          "anthropic.com"
        ],
        "domain": [
          "open-vsx.org",
          "mobile.events.data.microsoft.com",
          "o4507463137361920.ingest.us.sentry.io",
          "clientservices.googleapis.com",
          "daily-cloudcode-pa.googleapis.com"
        ],
        "server": "proxy-dns"
      }
    ],
    "final": "local-dns"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": ["172.19.0.1/30"],
      "mtu": 9000,
      "auto_route": true,
      "strict_route": false
    }
  ],
  "outbounds": [
    {
      "type": "socks",
      "tag": "proxy",
      "server": "127.0.0.1",
