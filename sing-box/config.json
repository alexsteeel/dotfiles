    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "process_name": [
          "pycharm",
          "rider",
          "datagrip",
          "goland",
          "writerside",
          "dataspell",
          "jetbrains-toolbox",
          "language_server_linux_x64",
          "claude",
          "codex",
          "gemini",
          "antigravity"
        ],
        "process_path": [
          "/usr/share/antigravity/antigravity",
          "/usr/share/antigravity/resources/app/extensions/antigravity/bin/language_server_linux_x64"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "domain_suffix": [
          "codeium.com",
          "jetbrains.com",
          "jetbrains.ai",
          "cloudflare.com",
          "cloudfront.net",
          "chatgpt.com",
          "openai.com",
          "anthropic.com"
